# candid-api environment variables.
# Copy to .env locally; in Render, populate via the `candid-api-env` env group.
# Never commit real values.

# --- Runtime ---
ENV=dev
LOG_LEVEL=INFO
# Comma-separated list of allowed CORS origins. Use "*" only in dev.
CORS_ALLOW_ORIGINS=*

# --- Supabase ---
# EU region — do NOT change to non-EU per CLAUDE.md.
# Get these from Supabase dashboard → Settings → API. See SUPABASE-SETUP.md for the
# step-by-step. SUPABASE_JWT_SECRET is verified on every protected route via PyJWT;
# SUPABASE_SERVICE_ROLE_KEY is the admin key used by app/clients/supabase.py — never
# bundle it into the mobile app. (The anon key belongs in candid-app/.env, not here.)
SUPABASE_REGION=eu-central-1
SUPABASE_URL=
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=

# --- Cloudflare R2 (S3-compatible) ---
# Bucket must be created in an EU jurisdiction.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_REGION=auto

# --- Firebase (FCM push) ---
# Paste the service account JSON as a single-line string.
FIREBASE_CREDENTIALS_JSON=

# --- Resend (magic-link email) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=
